      await kv.set(`sales:${userId}`, JSON.stringify([]));
      await kv.set(`ledger:${userId}`, JSON.stringify([]));
      await kv.set(`users:${userId}`, JSON.stringify([]));
      await kv.set(`suppliers:${userId}`, JSON.stringify([]));
await kv.set(`purchases:${userId}`, JSON.stringify([]));

      return c.json({
        message: "Super Admin account created successfully! You can now sign in.",
        status: "approved",
        userId,
      });
    }
    
    const pendingRequest = {
      id: userId,
