    return c.json({
      summary: {
        totalAssets,
        totalLiabilities,
        netWorth: totalAssets - totalLiabilities,
      },
      accounts: {
        all: accounts,
        byType: {
          bank: accounts.filter((acc: any) => acc.type === 'bank'),
          cash: accounts.filter((acc: any) => acc.type === 'cash'),
          receivables: accounts.filter((acc: any) => acc.type === 'receivable'),
          payables: accounts.filter((acc: any) => acc.type === 'payable'),
        },
      },
    });
