// Deposit into bank
app.post('/make-server-a01dd888/banks/:id/deposit', async (c) => {
  const auth = await getAuthenticatedShop(c.req.raw);
  if ('error' in auth) return c.json({ error: auth.error }, auth.status);

  try {
    const bankId = c.req.param('id');
    const { amount, description } = await c.req.json();

    const banksData = await kv.get(`banks:${auth.shopId}`);
    const banks = banksData ? JSON.parse(banksData) : [];

    const index = banks.findIndex((b: any) => b.id === bankId);
    if (index === -1) return c.json({ error: 'Bank not found' }, 404);

    banks[index].balance += amount;

    // Ledger entry
    const ledgerData = await kv.get(`ledger:${auth.shopId}`);
    const ledger = ledgerData ? JSON.parse(ledgerData) : [];
    const currentBalance = ledger.length > 0 ? ledger[0].balance : 0;

    const newEntry = {
      id: Date.now().toString(),
      date: new Date().toISOString(),
      type: 'bank_deposit',
      bankId,
      bankName: banks[index].name,
      description: description || `Deposit to ${banks[index].name}`,
      debit: 0,
      credit: amount,
      balance: currentBalance + amount,
    };
    ledger.unshift(newEntry);

    await kv.set(`banks:${auth.shopId}`, JSON.stringify(banks));
    await kv.set(`ledger:${auth.shopId}`, JSON.stringify(ledger));

    return c.json({ bank: banks[index], entry: newEntry });
  } catch (error) {
    console.log('Bank deposit error:', error);
    return c.json({ error: 'Failed to deposit' }, 500);
  }
});

// Withdraw from bank
app.post('/make-server-a01dd888/banks/:id/withdraw', async (c) => {
  const auth = await getAuthenticatedShop(c.req.raw);
  if ('error' in auth) return c.json({ error: auth.error }, auth.status);

  try {
    const bankId = c.req.param('id');
    const { amount, description } = await c.req.json();

    const banksData = await kv.get(`banks:${auth.shopId}`);
    const banks = banksData ? JSON.parse(banksData) : [];

    const index = banks.findIndex((b: any) => b.id === bankId);
    if (index === -1) return c.json({ error: 'Bank not found' }, 404);

    if (banks[index].balance < amount) {
      return c.json({ error: 'Insufficient bank balance' }, 400);
    }

    banks[index].balance -= amount;

    // Ledger entry
    const ledgerData = await kv.get(`ledger:${auth.shopId}`);
    const ledger = ledgerData ? JSON.parse(ledgerData) : [];
    const currentBalance = ledger.length > 0 ? ledger[0].balance : 0;

    const newEntry = {
      id: Date.now().toString(),
      date: new Date().toISOString(),
      type: 'bank_withdraw',
      bankId,
      bankName: banks[index].name,
      description: description || `Withdrawal from ${banks[index].name}`,
      debit: amount,
      credit: 0,
      balance: currentBalance - amount,
    };
    ledger.unshift(newEntry);

    await kv.set(`banks:${auth.shopId}`, JSON.stringify(banks));
    await kv.set(`ledger:${auth.shopId}`, JSON.stringify(ledger));

    return c.json({ bank: banks[index], entry: newEntry });
  } catch (error) {
    console.log('Bank withdraw error:', error);
    return c.json({ error: 'Failed to withdraw' }, 500);
  }
});

