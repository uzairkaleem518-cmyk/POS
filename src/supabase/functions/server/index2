  }

  try {
    const purchase = await c.req.json();
    
    // Get all related data
    const purchasesData = await kv.get(`purchases:${auth.shopId}`);
    const purchases = purchasesData ? JSON.parse(purchasesData) : [];
    
    const productsData = await kv.get(`products:${auth.shopId}`);
    const products = productsData ? JSON.parse(productsData) : [];
    
    const suppliersData = await kv.get(`suppliers:${auth.shopId}`);
    const suppliers = suppliersData ? JSON.parse(suppliersData) : [];
    
    const ledgerData = await kv.get(`ledger:${auth.shopId}`);
    const ledger = ledgerData ? JSON.parse(ledgerData) : [];
    
    // Create new purchase
    const newPurchase = {
      ...purchase,
      id: Date.now().toString(),
      date: new Date().toISOString(),
    };
    purchases.unshift(newPurchase);
    
    // Update product stock (INCREASE)
    // Update product stock AND cost price (INCREASE)
purchase.items.forEach((item: any) => {
  const productIndex = products.findIndex((p: any) => p.id === item.productId);
  if (productIndex !== -1) {
    products[productIndex].stock += item.quantity;
    products[productIndex].costPrice = item.price; // ADD THIS LINE - Save the buying price
  }
});
    
    // Update supplier balance if credit purchase
    if (purchase.paymentMethod === 'credit' && purchase.balance > 0) {
      const supplierIndex = suppliers.findIndex((s: any) => s.id === purchase.supplierId);
      if (supplierIndex !== -1) {
        suppliers[supplierIndex].balance += purchase.balance;
      }
    }
    
    // Add ledger entry (DEBIT - money out)
    const currentBalance = ledger.length > 0 ? ledger[0].balance : 0;
    const newLedgerEntry = {
      id: Date.now().toString(),
      date: new Date().toISOString(),
      type: 'purchase',
      supplierId: purchase.supplierId,
      supplierName: purchase.supplierName,
      description: `Purchase Order #${newPurchase.id.slice(-6)}`,
      debit: purchase.amountPaid,
      credit: 0,
      balance: currentBalance - purchase.amountPaid,
    };
    ledger.unshift(newLedgerEntry);
    
    // Save all updates
    await kv.set(`purchases:${auth.shopId}`, JSON.stringify(purchases));
    await kv.set(`products:${auth.shopId}`, JSON.stringify(products));
    await kv.set(`suppliers:${auth.shopId}`, JSON.stringify(suppliers));
