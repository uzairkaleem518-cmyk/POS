// POST: Record a double-entry transaction
app.post('/make-server-a01dd888/transactions', async (c) => {
  const auth = await getAuthenticatedShop(c.req.raw);
  if ('error' in auth) return c.json({ error: auth.error }, auth.status);

  try {
    const body = await c.req.json();
    const { debitAccountId, creditAccountId, amount, description, date, reference } = body;

    const accountsData = await kv.get(`accounts:${auth.shopId}`);
    let accounts = accountsData ? JSON.parse(accountsData) : [];

    // Double Entry Logic: Debit increases asset/expense, Credit decreases asset/revenue
    accounts = accounts.map((acc: any) => {
      if (acc.id === debitAccountId) {
        return { ...acc, balance: (acc.balance || 0) + Number(amount) };
      }
      if (acc.id === creditAccountId) {
        return { ...acc, balance: (acc.balance || 0) - Number(amount) };
      }
      return acc;
    });

    const newTransaction = {
      id: crypto.randomUUID(),
      shopId: auth.shopId,
      date,
      description,
      debitAccountId,
      creditAccountId,
      amount: Number(amount),
      reference,
      createdAt: new Date().toISOString()
    };

    const txnsData = await kv.get(`transactions:${auth.shopId}`);
    const transactions = txnsData ? JSON.parse(txnsData) : [];
    transactions.unshift(newTransaction);

    await kv.set(`accounts:${auth.shopId}`, JSON.stringify(accounts));
    await kv.set(`transactions:${auth.shopId}`, JSON.stringify(transactions));

    return c.json({ success: true, transaction: newTransaction });
  } catch (error) {
    console.error('Transaction Error:', error);
    return c.json({ error: 'Failed to process transaction' }, 500);
  }
});

