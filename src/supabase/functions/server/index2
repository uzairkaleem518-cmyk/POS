  const auth = await getAuthenticatedShop(c.req.raw);
  if ('error' in auth) {
    return c.json({ error: auth.error }, auth.status);
  }

  try {
    const { supplierId, amount, description } = await c.req.json();
    
    const suppliersData = await kv.get(`suppliers:${auth.shopId}`);
    const suppliers = suppliersData ? JSON.parse(suppliersData) : [];
    
    const ledgerData = await kv.get(`ledger:${auth.shopId}`);
    const ledger = ledgerData ? JSON.parse(ledgerData) : [];
    
    const supplierIndex = suppliers.findIndex((s: any) => s.id === supplierId);
    if (supplierIndex === -1) {
      return c.json({ error: 'Supplier not found' }, 404);
    }
    
    // Update supplier balance
    suppliers[supplierIndex].balance -= amount;
    
    // Add ledger entry
    const currentBalance = ledger.length > 0 ? ledger[0].balance : 0;
    const newEntry = {
      id: Date.now().toString(),
      date: new Date().toISOString(),
      type: 'supplier_payment',
      supplierId,
      supplierName: suppliers[supplierIndex].name,
      description: description || `Payment to ${suppliers[supplierIndex].name}`,
      debit: amount,
      credit: 0,
      balance: currentBalance - amount,
    };
    
    ledger.unshift(newEntry);
    
    await kv.set(`suppliers:${auth.shopId}`, JSON.stringify(suppliers));
    await kv.set(`ledger:${auth.shopId}`, JSON.stringify(ledger));
    
    return c.json({ entry: newEntry, supplier: suppliers[supplierIndex] });
